package web

templ Base(title, currentPath string, body templ.Component) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark"
		data-signals="{theme:'dark', q:'', status:'', selected:'', tabs:{}, since:'15m', from:'', to:''}"
		data-init="$theme = (document.documentElement.dataset.theme || 'dark')"
		data-attr:data-theme="$theme"
		data-effect="localStorage.setItem('theme', $theme)"
	>
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
			<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
			<script>document.documentElement.dataset.theme=localStorage.getItem('theme')||'dark';</script>
			<script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.1/bundles/datastar.js"></script>
			@styles()
		</head>
		<body>
			@topbar(currentPath)
			<main id="app">
				@body
			</main>
		</body>
	</html>
}

templ topbar(currentPath string) {
	<header class="topbar">
		<div class="brand">
			<a href="/">
				<span class="brand-dot"></span>
				Looper<b>Agent</b>
			</a>
		</div>
		<nav class="tabs">
			<a class={ "nav-link", templ.KV("active", currentPath == "/") } href="/">Dashboard</a>
			<a class={ "nav-link", templ.KV("active", isPathActive(currentPath, "/chats")) } href="/chats">Chats</a>
			<a class={ "nav-link", templ.KV("active", isPathActive(currentPath, "/runs")) } href="/runs">Traces</a>
		</nav>
		<div class="topbar-right">
			<div class="time-filter">
				<span class="time-icon" aria-hidden="true">⏱</span>
				<div class="time-pills" role="tablist" aria-label="Time range">
					for _, opt := range SinceOptions() {
						<button class="time-pill" type="button" role="tab" value={ opt.Value }
							data-class={ "{active: $since === '" + opt.Value + "'}" }
							data-on:click={ "$since = '" + opt.Value + "'; @get('/partials/time-refresh/" + opt.Value + "')" }>
							{ opt.Label }
						</button>
					}
					<button class="time-pill" type="button" role="tab"
						data-class={ "{active: $since === 'all'}" }
						data-on:click="$since = 'all'; $from = ''; $to = ''; @get('/partials/time-refresh/all')">all</button>
				</div>
				<div class="time-custom" data-show="$since === 'custom'">
					<input type="datetime-local" class="time-date-input" aria-label="From"
						data-bind:from
						data-on:change="@get('/partials/time-refresh/custom')"/>
					<span class="time-arrow" aria-hidden="true">→</span>
					<input type="datetime-local" class="time-date-input" aria-label="To"
						data-bind:to
						data-on:change="@get('/partials/time-refresh/custom')"/>
				</div>
			</div>
			<button class="icon-btn"
				data-on:click="$theme = $theme === 'dark' ? 'light' : 'dark'"
				aria-label="Toggle theme" title="Toggle theme">◐</button>
		</div>
	</header>
}

func isPathActive(currentPath, prefix string) bool {
	if currentPath == prefix {
		return true
	}
	return len(currentPath) > len(prefix) && currentPath[:len(prefix)] == prefix && currentPath[len(prefix)] == '/'
}
