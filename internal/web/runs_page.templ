package web

// RunsPage seeds the global signals from server state via data-signals (so a
// fresh page load with /runs/{id} restores $selected and the URL filter sticks).
// The sidebar auto-refreshes every 2 s by re-issuing the same idempotent GET.
templ RunsPage(data RunsViewData) {
	<div class="split fade-in"
		data-signals={
			"{q:'" + jsLit(data.Sidebar.Query) +
			"', status:'" + jsLit(data.Sidebar.Filter) +
			"', selected:'" + jsLit(selectedID(data.Sidebar.Selected)) + "'}",
		}
		data-init="@get('/sse/sidebar')">
		<aside class="split-aside">
			<div id="sidebar-body"
				style="display:flex;flex-direction:column;min-height:0;flex:1;">
				@SidebarBody(data.Sidebar)
			</div>
		</aside>
		<section class="split-main">
			<div id="detail-pane">
				if data.Detail != nil {
					@DetailPaneBody(*data.Detail)
				} else {
					@emptyDetail()
				}
			</div>
		</section>
	</div>
}

func selectedID(r *RunRecord) string {
	if r == nil {
		return ""
	}
	return r.ID
}

// jsLit escapes a string for safe embedding inside single-quoted JS literals.
// Used only when injecting server-side data into datastar expressions.
func jsLit(s string) string {
	out := make([]byte, 0, len(s))
	for i := 0; i < len(s); i++ {
		c := s[i]
		switch c {
		case '\\', '\'', '"':
			out = append(out, '\\', c)
		case '\n':
			out = append(out, '\\', 'n')
		case '\r':
			out = append(out, '\\', 'r')
		default:
			out = append(out, c)
		}
	}
	return string(out)
}

templ emptyDetail() {
	<div class="empty-state" style="margin-top:80px;">
		<span class="icon">∅</span>
		<p>
			No run selected.<br/>
			Pick one on the left.
		</p>
	</div>
}
