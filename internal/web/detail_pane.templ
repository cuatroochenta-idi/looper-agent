package web

import (
	"fmt"
	"html/template"
)

// copyExpr returns the datastar `data-on-click` expression for a copy button.
// Uses navigator.clipboard (browser-only API) plus `el` (the bound element).
// Briefly swaps the icon to ✓ as visual feedback.
func copyExpr(text string) string {
	return "navigator.clipboard.writeText('" + jsLit(text) +
		"').then(() => { el.textContent='✓'; el.classList.add('copied'); setTimeout(() => { el.textContent='⧉'; el.classList.remove('copied'); }, 900); })"
}

// tabSetExpr sets the active tab for a given callID. Tabs live in the global
// $tabs object keyed by sanitised call ID.
func tabSetExpr(callID, tab string) string {
	return "$tabs['" + jsLit(callID) + "'] = '" + tab + "'"
}

// tabIsExpr returns the JS expression that's true when the given tab is the
// active one. `defaultTab` is the tab to fall back to when the user hasn't
// clicked one yet — pass "result" for completed tool calls so the operator
// lands on the output, "args" otherwise.
func tabIsExpr(callID, tab, defaultTab string) string {
	return "($tabs['" + jsLit(callID) + "'] || '" + defaultTab + "') === '" + tab + "'"
}

// DetailPaneBody is the body of the /runs detail pane. The data-init wrapper
// opens the per-run SSE stream that keeps the trace tree live as new steps
// arrive. The chats page wraps detailPaneInner instead, since its enclosing
// /sse/chat-trace stream is what drives live updates there.
templ DetailPaneBody(data DetailData) {
	{{ streamURL := "@get('/sse/runs/" + data.Run.ID + "')" }}
	<div class={ "fade-in", templ.KV("is-live", data.Live) } data-init={ streamURL }>
		@detailPaneInner(data)
	</div>
}

// detailPaneInner renders the same content as DetailPaneBody without opening
// a /sse/runs/{id} stream. Use it whenever the parent context already owns
// the SSE subscription that keeps this fragment live — otherwise you end up
// with duplicate streams racing on the same selector.
templ detailPaneInner(data DetailData) {
	@detailHeader(data)
	@TraceTree(data.Timeline, data.Live, data.SpawnedByToolCall)
}

templ detailHeader(data DetailData) {
	<div class="run-header-sticky">
		<div class="run-title-row">
			<span class={ "badge", "badge-" + string(data.Run.Status) }>
				<span class="dot"></span>
				{ string(data.Run.Status) }
				if data.Live {
					<span class="badge-live">
						<span class="spin-ring"></span>
						refreshing
					</span>
				}
			</span>
			<span class="run-id-pill">
				<span class="lbl">run</span>
				<span class="mono">{ data.Run.ID }</span>
				<button class="copy-btn"
					data-on:click={ copyExpr(data.Run.ID) }
					title="Copy run ID">⧉</button>
			</span>
			<span style="font-size:11px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;">
				started { data.Run.StartedAt.Format("15:04:05.000") }
				if !data.Run.EndedAt.IsZero() {
					· { PrettyDuration(data.Timeline.Duration()) } duration
				}
			</span>
		</div>
		<div class="run-input-line">
			<span class="lbl">input</span>
			<span class="run-input-text">{ Truncate(data.Run.Input, 200) }</span>
		</div>
		<div class="metric-row">
			<div class="metric"><span class="lbl">turns</span><span class="val">{ fmt.Sprintf("%d", data.Run.Turns) }</span></div>
			<div class="metric">
				<span class="lbl">cost{ rollupCostLbl(data.RunRollup) }</span>
				<span class="val success">${ fmt.Sprintf("%.5f", data.RunRollup.TotalUSD()) }</span>
			</div>
			<div class="metric"><span class="lbl">input</span><span class="val">{ fmt.Sprintf("%d", data.Run.InputTokens) }</span></div>
			<div class="metric"><span class="lbl">output</span><span class="val">{ fmt.Sprintf("%d", data.Run.OutputTokens) }</span></div>
			if data.Run.CachedTokens > 0 {
				<div class="metric"><span class="lbl">cached</span><span class="val">{ fmt.Sprintf("%d", data.Run.CachedTokens) }</span></div>
			}
			<div class="metric"><span class="lbl">latency</span><span class="val">{ PrettyDuration(data.Timeline.Duration()) }</span></div>
			if data.Run.FallbackCalls > 0 {
				<div class="metric"><span class="lbl">fallback</span><span class="val warn">{ fmt.Sprintf("%d call%s", data.Run.FallbackCalls, pluralS(data.Run.FallbackCalls)) }</span></div>
			}
		</div>
		if data.RunRollup.HasSubs() {
			<div class="rollup-note">
				<span class="rollup-arrow">↳</span>
				incl. <b>{ fmt.Sprintf("%d", data.RunRollup.SubCount) }</b> sub-agent{ pluralS(data.RunRollup.SubCount) }:
				<b>+${ fmt.Sprintf("%.5f", data.RunRollup.SubUSD) }</b> · <b>+{ fmt.Sprintf("%d", data.RunRollup.SubTokens) }</b> tok
				<span class="rollup-self">self ${ fmt.Sprintf("%.5f", data.RunRollup.SelfUSD) } · { fmt.Sprintf("%d", data.RunRollup.SelfTokens) } tok</span>
			</div>
		}
		if len(data.Run.Providers) > 1 || (len(data.Run.Providers) == 1 && data.Run.FallbackCalls > 0) {
			<div class="provider-breakdown">
				<div class="section-label">providers · { fmt.Sprintf("%d", len(data.Run.Providers)) }</div>
				<table class="providers-table">
					<thead>
						<tr>
							<th>provider</th>
							<th>model</th>
							<th>calls</th>
							<th>in</th>
							<th>out</th>
							<th>cost</th>
						</tr>
					</thead>
					<tbody>
						for _, p := range data.Run.Providers {
							<tr>
								<td>
									{ p.Provider }
									if p.FallbackCalls > 0 {
										<span class="fallback-badge" title={ fmt.Sprintf("%d call%s via fallback", p.FallbackCalls, pluralS(p.FallbackCalls)) }>↪ fallback</span>
									}
								</td>
								<td>{ p.Model }</td>
								<td>{ fmt.Sprintf("%d", p.Calls) }</td>
								<td>{ fmt.Sprintf("%d", p.InputTokens) }</td>
								<td>{ fmt.Sprintf("%d", p.OutputTokens) }</td>
								<td>${ fmt.Sprintf("%.5f", p.TotalUSD) }</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		}
	</div>
}

templ TraceTree(tl RunTimeline, live bool, spawned map[string][]*SpawnedRun) {
	<div class="trace">
		<div class="section-label">trace · { fmt.Sprintf("%d", len(tl.Turns)) } turn{ pluralS(len(tl.Turns)) }</div>
		if tl.UserInput != nil {
			@userInputNode(*tl.UserInput)
		}
		if tl.SystemPrompt != nil {
			@systemPromptNode(*tl.SystemPrompt)
		}
		for i, turn := range tl.Turns {
			@turnNode(turn, tl, live && i == len(tl.Turns)-1 && turn.Final == nil, spawned)
		}
		if len(tl.Turns) == 0 {
			<div class="empty-state" style="padding:32px 16px;">
				<span class="icon">…</span>
				<p>Awaiting first step…</p>
			</div>
		}
	</div>
}

templ systemPromptNode(s TimelineStep) {
	<details class="node">
		<summary>
			<span class="caret">▸</span>
			<span class="node-kind k-system">system_prompt</span>
			<span class="node-title"><span class="preview">{ fmt.Sprintf("%d chars · loaded at start", len(s.Content)) }</span></span>
			<span class="node-meta"><span class="ts">{ s.At.Format("15:04:05.000") }</span></span>
		</summary>
		<div class="node-body">
			<div class="block-wrap">
				<button class="copy-btn" data-on:click={ copyExpr(s.Content) }>⧉</button>
				<pre class="block">{ s.Content }</pre>
			</div>
		</div>
	</details>
}

templ userInputNode(s TimelineStep) {
	<details class="node" open>
		<summary>
			<span class="caret">▸</span>
			<span class="node-kind k-user">user</span>
			<span class="node-title"><span class="preview">{ Truncate(s.Content, 140) }</span></span>
			<span class="node-meta"><span class="ts">{ s.At.Format("15:04:05.000") }</span></span>
		</summary>
		<div class="node-body">
			<div class="block-wrap">
				<button class="copy-btn" data-on:click={ copyExpr(s.Content) }>⧉</button>
				<pre class="block">{ s.Content }</pre>
			</div>
		</div>
	</details>
}

templ turnNode(turn TurnNode, tl RunTimeline, inFlight bool, spawned map[string][]*SpawnedRun) {
	<details class={ "node", templ.KV("tn-active", inFlight) } open>
		<summary>
			<span class="caret">▸</span>
			<span class="node-kind k-turn">turn { fmt.Sprintf("%d", turn.Index) }</span>
			<span class="node-title">
				if turn.Final != nil {
					<span class="preview preview-success">{ Truncate(turn.Final.Content, 140) }</span>
				} else if len(turn.ToolNodes) > 0 {
					<span class="preview">
						{ fmt.Sprintf("%d tool call%s", len(turn.ToolNodes), pluralS(len(turn.ToolNodes))) }
						if turn.AssistantText != "" {
							 · "{ Truncate(turn.AssistantText, 90) }"
						}
					</span>
				} else if turn.AssistantText != "" {
					<span class="preview">"{ Truncate(turn.AssistantText, 140) }"</span>
				} else if inFlight {
					<span class="preview">awaiting model response…</span>
				} else {
					<span class="preview">no content</span>
				}
			</span>
			<span class="node-meta">
				if inFlight {
					<span class="live-pill" title="this turn is in flight">
						<span class="spin-ring"></span>
						thinking
					</span>
				}
				if turnModelShort(turn) != "" {
					<span class="turn-model" title={ turnProviderTitle(turn) }>
						if turn.Fallback {
							<span class="turn-model-fb" title="answered via fallback">↪</span>
						}
						{ turnModelShort(turn) }
					</span>
				}
				if turn.HasTokens {
					<span class="tok">
						in&thinsp;<b>{ fmt.Sprintf("%d", turn.InTokens) }</b> · out&thinsp;<b>{ fmt.Sprintf("%d", turn.OutTokens) }</b>
						if turn.CachedToks > 0 {
							· cached&thinsp;<b>{ fmt.Sprintf("%d", turn.CachedToks) }</b>
						}
					</span>
				}
				if turn.LLMCall != nil {
					<span class="dur">{ PrettyDuration(turn.EndAt().Sub(turn.LLMCall.At)) }</span>
				}
				<span class="ts">{ turn.StartAt.Format("15:04:05.000") }</span>
			</span>
		</summary>
		<div class="node-body">
			if turn.LLMCall != nil {
				@llmCallNode(*turn.LLMCall, turn, inFlight)
			}
			if turn.Reasoning != "" {
				@reasoningNode(turn.Reasoning)
			}
			for _, tn := range turn.ToolNodes {
				@toolNode(tn, tl, spawned[tn.Call.ToolCallID])
			}
			if turn.Final != nil {
				@finalNode(*turn.Final)
			}
			if turn.Error != nil {
				@errorNode(*turn.Error)
			}
		</div>
	</details>
}

templ llmCallNode(s TimelineStep, turn TurnNode, inFlight bool) {
	{{
		// Skip duplicating the model's text in the LLM-call body when the
		// turn already renders it as the Final node — that node is more
		// prominent and would just repeat the same content here.
		showAssistantText := turn.AssistantText != "" && turn.Final == nil
		preview := ""
		switch {
		case turn.AssistantText != "":
			preview = Truncate(turn.AssistantText, 140)
		case turn.Final != nil:
			preview = "produced a final response"
		case inFlight:
			preview = "awaiting model response…"
		case len(turn.ToolNodes) > 0:
			preview = fmt.Sprintf("produced %d tool call%s", len(turn.ToolNodes), pluralS(len(turn.ToolNodes)))
		default:
			preview = "no visible content"
		}
	}}
	<details class={ "node", "depth-1", templ.KV("tn-active", inFlight) } open?={ showAssistantText }>
		<summary>
			<span class="caret">▸</span>
			<span class="node-kind k-llm">llm_call</span>
			if turn.Fallback {
				<span class="fallback-badge" title="this turn was answered via the FailoverProvider fallback path">↪ fallback</span>
			}
			if turn.Provider != "" {
				<span class="turn-provider" title={ turnProviderTitle(turn) }>{ turn.Provider }
					if turn.Model != "" {
						/{ turn.Model }
					}
					if turn.APIKeySuffix != "" {
						<span class="turn-key" title="API key suffix that served this turn">&nbsp;· { turn.APIKeySuffix }</span>
					}
				</span>
			}
			if len(turn.ChunkAttribution) > 1 {
				<span class="turn-multikey" title="this turn's stream interleaved fragments from multiple (provider, model, key) sources — see body for the breakdown">multi-source ({ fmt.Sprintf("%d", len(turn.ChunkAttribution)) })</span>
			}
			<span class="node-title">
				<span class="preview">{ preview }</span>
			</span>
			<span class="node-meta">
				if inFlight {
					<span class="spin-ring" title="awaiting model response"></span>
				}
				if turn.AssistantText != "" {
					<span class="tok" title="output characters in this assistant message">{ fmt.Sprintf("%d chars", len(turn.AssistantText)) }</span>
				}
				<span class="ts">{ s.At.Format("15:04:05.000") }</span>
			</span>
		</summary>
		<div class="node-body">
			if showAssistantText {
				<div class="io-label io-label-inline">model output</div>
				<div class="block-wrap">
					<button class="copy-btn" data-on:click={ copyExpr(turn.AssistantText) }>⧉</button>
					<pre class="block is-assistant">{ turn.AssistantText }</pre>
				</div>
			}
			<div class="field-meta">
				<span>turn <b>{ fmt.Sprintf("%d", s.Turn) }</b></span>
				if turn.HasTokens {
					<span class="callid-chip">in <b>{ fmt.Sprintf("%d", turn.InTokens) }</b></span>
					<span class="callid-chip">out <b>{ fmt.Sprintf("%d", turn.OutTokens) }</b></span>
					if turn.CachedToks > 0 {
						<span class="callid-chip">cached <b>{ fmt.Sprintf("%d", turn.CachedToks) }</b></span>
					}
				}
			</div>
		</div>
	</details>
}

templ toolNode(tn ToolCallNode, tl RunTimeline, children []*SpawnedRun) {
	{{ endAt := tn.Call.At }}
	if tn.Result != nil {
		{{ endAt = tn.Result.At }}
	}
	{{ geom := tl.SpanGeom(tn.Call.At, endAt) }}
	{{ cid := tn.Call.ToolCallID }}
	{{
		// Default the tab to "result" once a result exists — the operator's
		// usual question is "what did this call return", not "what did the
		// model send". "args" stays default for in-flight calls.
		defaultTab := "args"
		if tn.Result != nil {
			defaultTab = "result"
		}
		hasErr := tn.HasError()
	}}
	<details class={ "node", "depth-1", templ.KV("tn-active", tn.Result == nil), templ.KV("tn-tool-error", hasErr) } open?={ hasErr }>
		<summary>
			<span class="caret">▸</span>
			<span class={ "node-kind", templ.KV("k-tool", !hasErr), templ.KV("k-tool-error", hasErr) }>
				if hasErr {
					tool · error
				} else {
					tool
				}
			</span>
			<span class="tool-name">{ tn.Call.ToolName }</span>
			<span class="node-title">
				<span class="preview">({ ArgsPreview(tn.Call.ToolArgs) })</span>
				if tn.Result != nil {
					if hasErr {
						<span class="preview preview-error">→ { Truncate(tn.Result.Content, 140) }</span>
					} else {
						<span class="preview preview-success">→ { Truncate(tn.Result.Content, 140) }</span>
					}
				}
			</span>
			<span class="node-meta">
				if tn.Result == nil {
					<span class="spin-ring" title="executing"></span>
				}
				<span class="gantt-strip" title="position within run">
					<span class="gantt-bar b-tool" style={ ganttStyle(geom) }></span>
				</span>
				if tn.Result != nil {
					<span class="dur">{ PrettyDuration(tn.Result.At.Sub(tn.Call.At)) }</span>
				}
				<span class="ts">{ tn.Call.At.Format("15:04:05.000") }</span>
			</span>
		</summary>
		<div class="node-body">
			<div class="tab-bar">
				<button class="tab-btn"
					data-on:click={ tabSetExpr(cid, "args") }
					data-class={ "{active: " + tabIsExpr(cid, "args", defaultTab) + "}" }>arguments</button>
				if tn.Result != nil {
					<button class="tab-btn"
						data-on:click={ tabSetExpr(cid, "result") }
						data-class={ "{active: " + tabIsExpr(cid, "result", defaultTab) + "}" }>result</button>
					<button class="tab-btn"
						data-on:click={ tabSetExpr(cid, "both") }
						data-class={ "{active: " + tabIsExpr(cid, "both", defaultTab) + "}" }>both</button>
				}
			</div>
			<div data-show={ tabIsExpr(cid, "args", defaultTab) }>
				<div class="io-label io-label-inline">arguments</div>
				@jsonBlock(tn.Call.ToolArgs)
			</div>
			if tn.Result != nil {
				<div data-show={ tabIsExpr(cid, "result", defaultTab) }>
					<div class="io-label io-label-inline">result</div>
					@jsonBlock(tn.Result.Content)
				</div>
				<div class="tool-both-grid" data-show={ tabIsExpr(cid, "both", defaultTab) }>
					<div>
						<div class="io-label io-label-inline">arguments</div>
						@jsonBlock(tn.Call.ToolArgs)
					</div>
					<div>
						<div class="io-label io-label-inline">result</div>
						@jsonBlock(tn.Result.Content)
					</div>
				</div>
			}
			<div class="field-meta">
				if tn.Result != nil {
					<span>took <b class="mono">{ PrettyDuration(tn.Result.At.Sub(tn.Call.At)) }</b></span>
				} else {
					<span class="exec-live">
						<span class="spin-ring"></span>
						executing…
					</span>
				}
				<span class="callid-chip">
					{ cid }
					<button class="copy-btn" data-on:click={ copyExpr(cid) }>⧉</button>
				</span>
			</div>
			if len(children) > 0 {
				@spawnedRuns(children)
			}
		</div>
	</details>
}

// spawnedRuns renders the sub-agent runs a tool call kicked off. Each is a
// collapsible node: the summary is a mini status card, and expanding it renders
// the child's full trace inline (recursively, so deeper sub-agents nest too)
// instead of navigating away from the parent. An "open full ↗" link still
// swaps the main pane to the child for a focused view.
templ spawnedRuns(children []*SpawnedRun) {
	<div class="spawned-runs">
		<div class="spawned-label">
			<span class="spawned-arrow">↳</span>
			{ fmt.Sprintf("spawned %d sub-agent run%s", len(children), pluralS(len(children))) }
		</div>
		for _, c := range children {
			@spawnedRunNode(c)
		}
	</div>
}

templ spawnedRunNode(c *SpawnedRun) {
	<details class={ "spawn-node", "s-" + string(c.Run.Status) } open?={ c.Live }>
		<summary>
			<span class="caret">▸</span>
			<span class="spawn-bar"></span>
			<span class={ "spawn-status", "s-" + string(c.Run.Status) }>
				<span class="dot"></span>{ string(c.Run.Status) }
			</span>
			if c.Model != "" {
				<span class="turn-model">{ c.Model }</span>
			}
			<span class="spawn-node-input">{ Truncate(c.Run.Input, 90) }</span>
			<span class="spawn-node-meta">
				if c.Run.Status == RunRunning {
					<span class="spin-ring" title="running"></span>
				}
				<span><b>{ fmt.Sprintf("%d", c.Run.Turns) }</b>&thinsp;turns</span>
				<span class="sep">·</span>
				<span title={ rollupTitle(c.Rollup) }><b>${ fmt.Sprintf("%.4f", c.Rollup.TotalUSD()) }</b>
					if c.Rollup.HasSubs() {
						<span class="rollup-mini">+sub</span>
					}
				</span>
				<span class="sep">·</span>
				<span><b>{ fmt.Sprintf("%d", c.Rollup.TotalTokens()) }</b>&thinsp;tk</span>
				<span class="spawn-id mono">{ ShortID(c.Run.ID) }</span>
			</span>
		</summary>
		<div class="spawn-node-body">
			<div class="spawn-node-toolbar">
				<a class="spawn-open"
					href={ templ.URL("/runs/" + c.Run.ID) }
					data-on:click__prevent={ "$selected = '" + c.Run.ID + "'; @get('/partials/runs/" + c.Run.ID + "/pane')" }>open full ↗</a>
			</div>
			@TraceTree(c.Timeline, c.Live, c.Children)
		</div>
	</details>
}

// rollupTitle is the hover tooltip for a sub-agent's cost figure, breaking the
// rolled-up total into own vs nested-sub-agent spend.
func rollupTitle(c CostRollup) string {
	if !c.HasSubs() {
		return fmt.Sprintf("$%.5f · %d tok", c.SelfUSD, c.SelfTokens)
	}
	return fmt.Sprintf("self $%.5f (%d tok) · +%d sub-agent%s $%.5f (%d tok)",
		c.SelfUSD, c.SelfTokens, c.SubCount, pluralS(c.SubCount), c.SubUSD, c.SubTokens)
}

templ jsonBlock(raw string) {
	<div class="block-wrap">
		<button class="copy-btn" data-on:click={ copyExpr(raw) }>⧉</button>
		<pre class="block is-json">@templ.Raw(string(PrettyJSON(raw)))</pre>
	</div>
}

templ reasoningNode(text string) {
	<details class="node depth-1 reasoning-node">
		<summary>
			<span class="caret">▸</span>
			<span class="node-kind k-reasoning">reasoning</span>
			<span class="node-title">
				<span class="preview">{ Truncate(text, 120) }</span>
			</span>
			<span class="node-meta">
				<span class="tok">{ fmt.Sprintf("%d chars", len(text)) }</span>
			</span>
		</summary>
		<div class="node-body">
			<pre class="block is-reasoning">{ text }</pre>
		</div>
	</details>
}

templ finalNode(s TimelineStep) {
	<details class="node depth-1" open>
		<summary>
			<span class="caret">▸</span>
			<span class="node-kind k-final">final</span>
			<span class="node-title"><span class="preview preview-success">{ Truncate(s.Content, 120) }</span></span>
			<span class="node-meta"><span class="ts">{ s.At.Format("15:04:05.000") }</span></span>
		</summary>
		<div class="node-body">
			<div class="block-wrap">
				<button class="copy-btn" data-on:click={ copyExpr(s.Content) }>⧉</button>
				<pre class="block">{ s.Content }</pre>
			</div>
		</div>
	</details>
}

templ errorNode(s TimelineStep) {
	<details class="node depth-1" open>
		<summary>
			<span class="caret">▸</span>
			<span class="node-kind k-error">error</span>
			<span class="node-title"><span class="preview">{ s.Err }</span></span>
			<span class="node-meta"><span class="ts">{ s.At.Format("15:04:05.000") }</span></span>
		</summary>
		<div class="node-body">
			<pre class="block">{ s.Err }</pre>
		</div>
	</details>
}

func ganttStyle(g SpanGeom) templ.SafeCSS {
	return templ.SafeCSS(fmt.Sprintf("left:%.2f%%;width:%.2f%%", g.Offset, g.Width))
}

func pluralS(n int) string {
	if n == 1 {
		return ""
	}
	return "s"
}

// rollupCostLbl appends " · total" to the cost metric label when a run's cost
// includes sub-agents, so it's clear the headline number is the rolled-up
// figure and not just the parent's own spend.
func rollupCostLbl(c CostRollup) string {
	if c.HasSubs() {
		return " · total"
	}
	return ""
}

// turnModelShort is the compact model label shown on the turn summary line —
// the model name when known, falling back to the provider. Empty for legacy
// traces with no provenance.
func turnModelShort(t TurnNode) string {
	if t.Model != "" {
		return t.Model
	}
	return t.Provider
}

// turnProviderTitle composes a hover tooltip for the provider badge shown
// next to llm_call. Surfaces the same info the per-step trace already
// stores but in a format readable at a glance — "openai · gpt-x · ****a2Fn ·
// fallback" when applicable. Empty when the turn has no provenance
// (legacy trace).
func turnProviderTitle(t TurnNode) string {
	if t.Provider == "" {
		return ""
	}
	out := t.Provider
	if t.Model != "" {
		out += " · " + t.Model
	}
	if t.APIKeySuffix != "" {
		out += " · " + t.APIKeySuffix
	}
	if t.Fallback {
		out += " · fallback"
	}
	return out
}

// ChatTraceBody is patched into #chat-trace by the /sse/chat-trace/{id}
// stream. The stream re-renders this whole fragment every time a step lands
// on the run, so we render detailPaneInner directly: there is no nested
// data-init that would open a second /sse/runs/{id} subscription competing
// for the same DOM (which is what kept the trace stale before).
templ ChatTraceBody(data DetailData) {
	<div class="chat-trace-inner fade-in">
		<div class="chat-trace-bar">
			<div class="chat-trace-bar-left">
				<span class={ "badge", "badge-" + string(data.Run.Status) }>
					<span class="dot"></span>{ string(data.Run.Status) }
				</span>
				<span class="mono" style="font-size:11.5px;color:var(--text-muted);">{ ShortID(data.Run.ID) }</span>
			</div>
			<div class="chat-trace-bar-right">
				if data.Run.TotalUSD > 0 {
					<span class="chat-trace-cost">${ fmt.Sprintf("%.4f", data.Run.TotalUSD) }</span>
				}
				<button class="chat-trace-close" type="button"
					title="Close detail panel" aria-label="Close detail panel"
					data-on:click="$selected = ''">×</button>
			</div>
		</div>
		<div id="detail-pane">
			@detailPaneInner(data)
		</div>
	</div>
}

var _ = template.HTML("")
